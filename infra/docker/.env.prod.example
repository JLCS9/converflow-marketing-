# Production env for docker-compose.prod.yml on the VPS.
# Copy to infra/docker/.env.prod with chmod 600 — never committed.

# --- Public hostnames (configured in nginx host-side, not in compose) ---
WEB_HOST=app.converflow.ai
ADMIN_HOST=admin.converflow.ai
API_HOST=api.converflow.ai

# --- Host ports (nginx proxies to these on 127.0.0.1) ---
WEB_HOST_PORT=8090
API_HOST_PORT=8091
BOT_RUNNER_HOST_PORT=8092
POSTGRES_HOST_PORT=55432

# --- Database (internal to converflow_ai_net) ---
POSTGRES_USER=converflow
POSTGRES_PASSWORD=CHANGEME-strong-password
POSTGRES_DB=converflow_ai
DATABASE_URL=postgresql://converflow:CHANGEME-strong-password@postgres:5432/converflow_ai?schema=public
DATABASE_DIRECT_URL=postgresql://converflow:CHANGEME-strong-password@postgres:5432/converflow_ai?schema=public

# --- Redis ---
REDIS_PASSWORD=CHANGEME-strong-redis-password
REDIS_URL=redis://default:CHANGEME-strong-redis-password@redis:6379

# --- Secrets (generate with: openssl rand -base64 32 / -hex 32) ---
AUTH_SECRET=CHANGEME-base64-32
ENCRYPTION_KEY=CHANGEME-hex-64
BOT_RUNNER_INTERNAL_TOKEN=CHANGEME-base64-32

# --- LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=noreply@converflow.ai

# --- Object storage (any S3-compatible: Cloudflare R2 / AWS S3 / B2 / MinIO / Wasabi) ---
# For Cloudflare R2:
#   S3_REGION=auto
#   S3_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com
# For AWS S3:
#   S3_REGION=eu-west-1 (or your region)
#   leave S3_ENDPOINT empty
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=converflow-docs

# --- Web URLs exposed to the browser ---
NEXT_PUBLIC_API_URL=https://api.converflow.ai
NEXT_PUBLIC_SITE_URL=https://converflow.ai
WEB_PUBLIC_URL=https://app.converflow.ai
ADMIN_PUBLIC_URL=https://admin.converflow.ai

# --- Runtime ---
NODE_ENV=production
SUPER_ADMIN_BOOTSTRAP_EMAIL=jose@csodigital.tech

{
  "name": "@converflow/api",
  "version": "0.0.0",
  "private": true,
  "description": "converflow.ai HTTP API (NestJS + Fastify)",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@converflow/db": "workspace:*",
    "@converflow/shared": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.10",
    "fastify": "^4.29.0",
    "ioredis": "5.10.1",
    "mjml": "^4.18.0",
    "nodemailer": "^8.0.9",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@converflow/config": "workspace:*",
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

{
  "extends": "@converflow/config/tsconfig.nestjs.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },
    "declaration": false,
    "declarationMap": false,
    "composite": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}

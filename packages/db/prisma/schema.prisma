// =====================================================================
// converflow.ai — Prisma schema
//
// Multitenant pool model. Tenant-scoped tables enforce isolation via
// Postgres Row Level Security. The API sets `app.tenant_id` per request
// in a transaction-scoped session variable (see packages/db/src/rls.ts).
//
// Platform-level tables (PlatformAdmin*, AppVersion) have no tenant_id
// and are accessed only through admin context.
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [pgcrypto, vector]
}

// ============================================
// PLATFORM (no tenant scope, no RLS)
// ============================================

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  status       AdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     PlatformAdminSession[]
  actions      AdminActionLog[]

  @@map("platform_admins")
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

model PlatformAdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
  @@map("platform_admin_sessions")
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      PlatformAdmin @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("admin_action_log")
}

model AppVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  releasedAt  DateTime
  title       String
  description String
  highlights  Json?
  createdAt   DateTime @default(now())

  @@index([releasedAt])
  @@map("app_versions")
}

// ============================================
// TENANT-SCOPED (RLS enforced)
// ============================================

model Tenant {
  id                       String   @id @default(cuid())
  slug                     String   @unique
  name                     String
  status                   TenantStatus @default(TRIAL)

  // Limits controlled by super admin
  maxUsers                 Int      @default(20)
  maxBots                  Int      @default(1)
  maxConversationsPerMonth Int      @default(5000)
  maxStorageGb             Int      @default(5)

  // Kit Digital tracking
  kitDigitalSegment     String?
  kitDigitalActivatedAt DateTime?

  // Metadata
  contactEmail String
  contactPhone String?
  timezone     String   @default("Europe/Madrid")
  locale       String   @default("es-ES")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  suspendedAt DateTime?

  users         User[]
  invitations   TenantInvitation[]
  bots          Bot[]
  agents        Agent[]
  accessLogs    AccessLog[]
  clients       Client[]
  leads         Lead[]
  opportunities Opportunity[]
  tasks         Task[]
  documents     Document[]
  notes         Note[]
  alerts        Alert[]
  aiUsage       AiUsage[]

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id                 String     @id @default(cuid())
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email              String     @unique
  name               String
  passwordHash       String
  role               UserRole   @default(AGENT_USER)
  status             UserStatus @default(ACTIVE)
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  sessions UserSession[]

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  BUILDER
  AGENT_USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model UserSession {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model TenantInvitation {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       UserRole  @default(AGENT_USER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([token])
  @@map("tenant_invitations")
}

// Kit Digital requirement: per-user access logs, stored in DB,
// exportable to CSV/JSON with date + user + email.
model AccessLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  email     String
  action    String
  resource  String?
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([email])
  @@map("access_logs")
}

model Bot {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  channel     Channel
  phoneNumber String?
  status      BotStatus @default(PENDING)
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])

  // Rate limits (overridable per bot, otherwise tenant default)
  maxMessagesPerMinute Int @default(60)
  maxMessagesPerHour   Int @default(1500)
  warmupUntil          DateTime?

  lastConnectedAt      DateTime?
  lastDisconnectAt     DateTime?
  lastDisconnectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session BotSession?

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("bots")
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  WEBCHAT
}

enum BotStatus {
  PENDING
  AWAITING_QR
  CONNECTING
  CONNECTED
  DISCONNECTED
  BANNED
  ERROR
}

model BotSession {
  botId              String @id
  tenantId           String
  bot                Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  authStateEncrypted Bytes
  encryptionVersion  Int    @default(1)
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@map("bot_sessions")
}

model Agent {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  systemPrompt String
  model        String      @default("claude-sonnet-4-6")
  config       Json
  status       AgentStatus @default(DRAFT)
  version      Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  bots Bot[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("agents")
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// CRM (tenant-scoped, RLS enforced)
// ============================================

model Client {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  nif       String?
  address   String?
  website   String?
  source    String?
  status    ClientStatus @default(ACTIVE)
  ownerId   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  leads         Lead[]
  opportunities Opportunity[]
  tasks         Task[]
  documents     Document[]
  notes         Note[]

  @@index([tenantId])
  @@index([status])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Lead {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)

  name        String
  email       String?
  phone       String?
  company     String?
  source      String?
  status      LeadStatus @default(NEW)
  score       Int?
  ownerId     String?
  customFields Json?

  // AI-generated context (Sprint 3 lead scoring)
  aiScoreReasoning String?
  aiScoreActions   Json?
  aiScoredAt       DateTime?

  contactedAt DateTime?
  qualifiedAt DateTime?

  opportunities Opportunity[]
  tasks         Task[]
  notes         Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, score])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Opportunity {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId            String?
  lead              Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  name              String
  amount            Decimal?      @db.Decimal(12, 2)
  currency          String        @default("EUR")
  status            OppStatus     @default(OPEN)
  probability       Int           @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?

  ownerId           String?
  proposalUrl       String?

  tasks     Task[]
  documents Document[]
  notes     Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expectedCloseDate])
  @@map("opportunities")
}

enum OppStatus {
  OPEN
  QUOTED
  NEGOTIATING
  WON
  LOST
}

model Task {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  ownerId     String?
  dueAt       DateTime?
  completedAt DateTime?

  // For tasks auto-generated by the AI agent / workflow engine
  source      String     @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, ownerId, status])
  @@index([tenantId, dueAt])
  @@map("tasks")
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Document {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  name       String
  mimeType   String
  sizeBytes  Int
  storageKey String

  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([clientId])
  @@index([opportunityId])
  @@map("documents")
}

model Note {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  body      String
  authorId  String

  // AI classification (Sprint 3.2 — Journeys de venta)
  aiCategory          NoteCategory?
  aiSentiment         NoteSentiment?
  aiConfidence        Float?
  aiSuggestedReply    String?
  aiAnalyzedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, aiCategory])
  @@map("notes")
}

enum NoteCategory {
  BUY_INTENT
  OBJECTION
  INFO_REQUEST
  COMPLAINT
  SCHEDULING
  OFF_TOPIC
  OTHER
}

enum NoteSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  URGENT
}

model Alert {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         AlertType
  severity     AlertSeverity @default(INFO)
  title        String
  description  String?

  resourceType String
  resourceId   String

  readAt      DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, readAt])
  @@map("alerts")
}

enum AlertType {
  LEAD_STALE
  OPPORTUNITY_DUE
  TASK_OVERDUE
  HIGH_SCORE_LEAD
  CLIENT_INACTIVITY
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ============================================
// AI usage tracking (cost + audit)
// ============================================

model AiUsage {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature      String   // 'lead_scoring', 'classify_message', 'chat_assistant', etc.
  model        String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  costUsd      Float?
  durationMs   Int?
  status       AiUsageStatus @default(OK)
  errorMessage String?
  resourceType String?  // 'lead', 'opportunity', 'note', etc.
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, feature])
  @@map("ai_usage")
}

enum AiUsageStatus {
  OK
  ERROR
}

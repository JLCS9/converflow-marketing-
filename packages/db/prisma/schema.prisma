// =====================================================================
// converflow.ai — Prisma schema
//
// Multitenant pool model. Tenant-scoped tables enforce isolation via
// Postgres Row Level Security. The API sets `app.tenant_id` per request
// in a transaction-scoped session variable (see packages/db/src/rls.ts).
//
// Platform-level tables (PlatformAdmin*, AppVersion) have no tenant_id
// and are accessed only through admin context.
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [pgcrypto, vector]
}

// ============================================
// PLATFORM (no tenant scope, no RLS)
// ============================================

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  status       AdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     PlatformAdminSession[]
  actions      AdminActionLog[]

  @@map("platform_admins")
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

model PlatformAdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
  @@map("platform_admin_sessions")
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      PlatformAdmin @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("admin_action_log")
}

model AppVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  releasedAt  DateTime
  title       String
  description String
  highlights  Json?
  createdAt   DateTime @default(now())

  @@index([releasedAt])
  @@map("app_versions")
}

// ============================================
// TENANT-SCOPED (RLS enforced)
// ============================================

model Tenant {
  id                       String   @id @default(cuid())
  slug                     String   @unique
  name                     String
  status                   TenantStatus @default(TRIAL)

  // Limits controlled by super admin
  maxUsers                 Int      @default(20)
  maxBots                  Int      @default(1)
  maxConversationsPerMonth Int      @default(5000)
  maxStorageGb             Int      @default(5)

  // Kit Digital tracking
  kitDigitalSegment     String?
  kitDigitalActivatedAt DateTime?

  // Metadata
  contactEmail String
  contactPhone String?
  timezone     String   @default("Europe/Madrid")
  locale       String   @default("es-ES")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  suspendedAt DateTime?

  users         User[]
  invitations   TenantInvitation[]
  apiKeys       ApiKey[]
  bots          Bot[]
  agents        Agent[]
  accessLogs    AccessLog[]
  clients       Client[]
  leads         Lead[]
  opportunities Opportunity[]
  tasks         Task[]
  documents     Document[]
  notes         Note[]
  alerts        Alert[]
  aiUsage       AiUsage[]
  calendarConnections CalendarConnection[]
  conversations Conversation[]
  messages      Message[]
  emailConnections EmailConnection[]
  customFieldDefinitions CustomFieldDefinition[]
  pipelines              Pipeline[]
  leadScoreBatches       LeadScoreBatch[]
  campaigns              Campaign[]
  campaignRecipients     CampaignRecipient[]
  suppressions           Suppression[]

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id                 String     @id @default(cuid())
  tenantId           String
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email              String     @unique
  name               String
  passwordHash       String
  role               UserRole   @default(AGENT_USER)
  status             UserStatus @default(ACTIVE)
  // Optional per-user permission override. When null, the user inherits the
  // role's defaults from @converflow/shared/permissions. When set, it is the
  // explicit list of allowed PermissionModule values. OWNER ignores this
  // field at runtime — they always have full access.
  permissions        Json?
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  sessions UserSession[]
  calendarConnection CalendarConnection?
  assignedTasks Task[]

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  BUILDER
  AGENT_USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model UserSession {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model TenantInvitation {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       UserRole  @default(AGENT_USER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([token])
  @@map("tenant_invitations")
}

/// Long-lived bearer token for the public REST API.
/// `prefix` is the visible "cfai_XXXXX" portion shown in the UI and used to
/// look up the row before doing a constant-time hash compare against
/// `keyHash` (sha256 of the full secret). The plaintext is shown to the
/// admin once at creation and never stored.
model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  prefix      String    @unique
  keyHash     String
  /// Array of PermissionModule strings (same enum used for users).
  scopes      Json
  createdBy   String
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedBy   String?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([prefix])
  @@map("api_keys")
}

// Kit Digital requirement: per-user access logs, stored in DB,
// exportable to CSV/JSON with date + user + email.
model AccessLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  email     String
  action    String
  resource  String?
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([email])
  @@map("access_logs")
}

// Bot reply behaviour per channel — moved here from Agent so a single
// conversational agent can be SUGGEST on WhatsApp and AUTO on WebChat.
enum BotReplyMode {
  OFF
  SUGGEST
  AUTO
}

model Bot {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  channel     Channel
  phoneNumber String?
  status      BotStatus @default(PENDING)
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])

  // How the bot should reply to inbound messages. Moved from Agent so the
  // same conversational agent can be wired AUTO on a low-stakes channel
  // (web chat) and SUGGEST on a high-stakes one (WhatsApp).
  replyMode   BotReplyMode @default(SUGGEST)

  // Rate limits (overridable per bot, otherwise tenant default)
  maxMessagesPerMinute Int @default(60)
  maxMessagesPerHour   Int @default(1500)
  warmupUntil          DateTime?

  lastConnectedAt      DateTime?
  lastDisconnectAt     DateTime?
  lastDisconnectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session BotSession?
  conversations Conversation[]
  emailConnection EmailConnection?
  campaigns Campaign[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("bots")
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  WEBCHAT
  EMAIL
}

enum BotStatus {
  PENDING
  AWAITING_QR
  CONNECTING
  CONNECTED
  DISCONNECTED
  BANNED
  ERROR
}

model BotSession {
  botId              String @id
  tenantId           String
  bot                Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  authStateEncrypted Bytes
  encryptionVersion  Int    @default(1)
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@map("bot_sessions")
}

model Agent {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  systemPrompt String
  model        String      @default("claude-sonnet-4-6")
  config       Json
  status       AgentStatus @default(DRAFT)
  // Runtime engine. See enum AgentType below.
  type         AgentType   @default(CONVERSATIONAL)
  // Wizard template the agent was created from (e.g. "agenda",
  // "oportunidades", "soporte"). Used for analytics + prefilling the same
  // form again on edit. Not part of the runtime contract.
  template     String?
  version      Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  bots          Bot[]
  scoreBatches  LeadScoreBatch[]

  @@unique([tenantId, name])
  @@index([tenantId, type])
  @@map("agents")
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// The wizard shows 12 funnel "purposes" but they collapse into three
// runtime engines. The chosen wizard tile is persisted in Agent.template
// (free string) alongside this enum.
//   CONVERSATIONAL → talks to people in a channel
//   OPPORTUNITIES  → batch-processes leads, scores them, opens opps
//   UTILITY        → headless data work (enrich, cleanup, report, summarize)
enum AgentType {
  CONVERSATIONAL
  OPPORTUNITIES
  UTILITY
}

/// Batch of bulk lead-scoring jobs. The API enqueues one row of N jobs and
/// updates `completed`/`failed` as the worker progresses; the frontend polls
/// for ETA + summary.
model LeadScoreBatch {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId       String?
  agent         Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  status        LeadScoreBatchStatus @default(QUEUED)
  total         Int
  completed     Int                 @default(0)
  failed        Int                 @default(0)
  statusUpdated Int                 @default(0)
  oppsCreated   Int                 @default(0)
  options       Json                // { updateStatus, createOpportunities }
  errors        Json                @default("[]")
  startedAt     DateTime?
  finishedAt    DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId, status])
  @@map("lead_score_batches")
}

enum LeadScoreBatchStatus {
  QUEUED
  RUNNING
  DONE
  CANCELLED
  FAILED
}

// ============================================
// CRM (tenant-scoped, RLS enforced)
// ============================================

model Client {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  lastName  String?
  email     String?
  phone     String?
  source    String?
  status    ClientStatus @default(ACTIVE)
  ownerId   String?
  customFields Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  leads         Lead[]
  opportunities Opportunity[]
  tasks         Task[]
  documents     Document[]
  notes         Note[]

  @@index([tenantId])
  @@index([status])
  @@map("clients")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Lead {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)

  name        String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  source      String?
  status      LeadStatus @default(LEAD)
  score       Int?
  ownerId     String?
  customFields Json?

  // AI-generated context (Sprint 3 lead scoring)
  aiScoreReasoning String?
  aiScoreActions   Json?
  aiScoredAt       DateTime?

  contactedAt DateTime?
  qualifiedAt DateTime?
  convertedAt DateTime? // stamped once when the lead first becomes CLIENT (Sprint 10 metrics)

  opportunities Opportunity[]
  tasks         Task[]
  notes         Note[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, score])
  @@map("leads")
}

// Status flow simplified to three values:
//   LEAD   -> sigue siendo un lead (cualquier estado previo a "ganado")
//   CLIENT -> ya es cliente (antes "CONVERTED")
//   LOST   -> oportunidad perdida
// Old values (NEW, CONTACTED, QUALIFIED, CONVERTED) stay in the enum for the
// duration of one deploy so the seed can migrate them in place; they're not
// exposed in the UI and a follow-up sprint will drop them once every tenant
// is on the new triplet.
enum LeadStatus {
  LEAD
  CLIENT
  LOST
  NEW         @map("NEW")
  CONTACTED   @map("CONTACTED")
  QUALIFIED   @map("QUALIFIED")
  CONVERTED   @map("CONVERTED")
}

model Opportunity {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId            String?
  lead              Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  name              String
  amount            Decimal?      @db.Decimal(12, 2)
  currency          String        @default("EUR")
  status            OppStatus     @default(OPEN)
  probability       Int           @default(50)
  expectedCloseDate DateTime?
  closedAt          DateTime?

  ownerId           String?
  proposalUrl       String?
  customFields      Json?

  pipelineId String?
  pipeline   Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stageId    String?
  stage      PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  tasks     Task[]
  documents Document[]
  notes     Note[]
  stageHistory OpportunityStageHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expectedCloseDate])
  @@index([tenantId, pipelineId, stageId])
  @@map("opportunities")
}

// ============================================
// Per-tenant customization
// CustomFieldDefinition: tenant-defined attributes for Lead/Client/Opportunity.
// Values live in the entity's `customFields` Json column keyed by `key`.
// Pipeline + PipelineStage: tenant-defined opportunity boards.
// ============================================

model CustomFieldDefinition {
  id         String              @id @default(cuid())
  tenantId   String
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType CustomFieldEntity
  key        String              // stable slug used as Json property name
  label      String
  type       CustomFieldType
  required   Boolean             @default(false)
  options    Json?               // SELECT/MULTISELECT options: [{value,label}]
  helpText   String?
  order      Int                 @default(0)
  archivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType])
  @@map("custom_field_definitions")
}

enum CustomFieldEntity {
  LEAD
  CLIENT
  OPPORTUNITY
}

enum CustomFieldType {
  TEXT
  LONGTEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  URL
  EMAIL
  PHONE
  DOCUMENT
}

model Pipeline {
  id         String          @id @default(cuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  entityType PipelineEntity  @default(OPPORTUNITY)
  isDefault  Boolean         @default(false)
  archivedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  stages        PipelineStage[]
  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId, entityType])
  @@map("pipelines")
}

enum PipelineEntity {
  OPPORTUNITY
}

model PipelineStage {
  id         String   @id @default(cuid())
  tenantId   String
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  key        String   // stable slug, scoped to pipeline
  label      String
  color      String   @default("#3B82F6")
  order      Int      @default(0)
  isWon      Boolean  @default(false)
  isLost     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  opportunities Opportunity[]
  history       OpportunityStageHistory[]

  @@unique([pipelineId, key])
  @@index([tenantId, pipelineId])
  @@map("pipeline_stages")
}

model OpportunityStageHistory {
  id            String   @id @default(cuid())
  tenantId      String
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  stageId       String
  stage         PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  movedAt       DateTime @default(now())
  movedBy       String?

  @@index([opportunityId, movedAt])
  @@index([tenantId, movedAt])
  @@map("opportunity_stage_history")
}

enum OppStatus {
  OPEN
  QUOTED
  NEGOTIATING
  WON
  LOST
}

model Task {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  ownerId     String?
  owner       User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  dueAt       DateTime?
  completedAt DateTime?

  // For tasks auto-generated by the AI agent / workflow engine
  source      String     @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, ownerId, status])
  @@index([tenantId, dueAt])
  @@map("tasks")
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  FOLLOW_UP
  SUPPORT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Document {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  name       String
  mimeType   String
  sizeBytes  Int
  storageKey String

  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([clientId])
  @@index([opportunityId])
  @@map("documents")
}

model Note {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  body      String
  authorId  String

  // AI classification (Sprint 3.2 — Journeys de venta)
  aiCategory          NoteCategory?
  aiSentiment         NoteSentiment?
  aiConfidence        Float?
  aiSuggestedReply    String?
  aiAnalyzedAt        DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, aiCategory])
  @@map("notes")
}

enum NoteCategory {
  BUY_INTENT
  OBJECTION
  INFO_REQUEST
  COMPLAINT
  SCHEDULING
  OFF_TOPIC
  OTHER
}

enum NoteSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  URGENT
}

model Alert {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         AlertType
  severity     AlertSeverity @default(INFO)
  title        String
  description  String?

  resourceType String
  resourceId   String

  readAt      DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, readAt])
  @@map("alerts")
}

enum AlertType {
  LEAD_STALE
  OPPORTUNITY_DUE
  TASK_OVERDUE
  HIGH_SCORE_LEAD
  CLIENT_INACTIVITY
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ============================================
// AI usage tracking (cost + audit)
// ============================================

model AiUsage {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature      String   // 'lead_scoring', 'classify_message', 'chat_assistant', etc.
  model        String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  costUsd      Float?
  durationMs   Int?
  status       AiUsageStatus @default(OK)
  errorMessage String?
  resourceType String?  // 'lead', 'opportunity', 'note', etc.
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, feature])
  @@map("ai_usage")
}

enum AiUsageStatus {
  OK
  ERROR
}

// ============================================
// Calendar integration (Sprint 5 — IA Reuniones)
// One Google account connection per user (tenant-scoped via RLS).
// Tokens are stored encrypted (aes-256-gcm) — see common/utils/crypto.ts.
// ============================================
model CalendarConnection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    String @default("google")
  googleEmail String

  refreshTokenEnc      String // encrypted refresh token
  accessTokenEnc       String? // encrypted, short-lived
  accessTokenExpiresAt DateTime?
  scope                String?
  calendarId           String @default("primary")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("calendar_connections")
}

// ============================================
// Conversations inbox (Sprint 8 — Chats)
// One conversation per (tenant, channel, contact). Messages are the transcript
// (IN = received, OUT = sent — incl. replies the user sends from their own
// WhatsApp, captured via Baileys fromMe). Classification lives on inbound msgs.
// ============================================
model Conversation {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botId    String?
  bot      Bot?    @relation(fields: [botId], references: [id], onDelete: SetNull)
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agentId  String? // optional override: agent for this conversation (e.g. set by a campaign)

  channel      Channel            @default(WHATSAPP)
  contactJid   String // stable contact id per channel (WA lid/pn, email address, webchat session)
  contactName  String?
  contactPhone String? // resolved real phone (+prefix) when available
  emailSubject String? // original subject (EMAIL channel) for reply threading

  status             ConversationStatus @default(PENDING)
  lastMessageAt      DateTime?
  lastMessagePreview String?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  unreadCount        Int                @default(0)
  assignedUserId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([tenantId, channel, contactJid])
  @@index([tenantId, status, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction   MessageDirection
  waMessageId String?
  body        String?
  mediaType   String? // null = text; 'image'|'video'|'document'|… otherwise

  // AI classification (inbound only)
  aiCategory       NoteCategory?
  aiSentiment      NoteSentiment?
  aiConfidence     Float?
  aiSuggestedReply String?
  aiAnalyzedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([tenantId, waMessageId])
  @@map("messages")
}

enum ConversationStatus {
  PENDING // last message inbound, awaiting reply
  ANSWERED // replied
  CLOSED // manually archived
}

enum MessageDirection {
  IN
  OUT
}

// ============================================
// Email channel connection (tenant connects their own mailbox via IMAP/SMTP).
// One per EMAIL bot. Credentials stored encrypted (aes-256-gcm).
// ============================================
model EmailConnection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botId    String @unique
  bot      Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  email       String
  imapHost    String
  imapPort    Int     @default(993)
  smtpHost    String
  smtpPort    Int     @default(465)
  username    String
  passwordEnc String // encrypted IMAP/SMTP password
  secure      Boolean @default(true)

  status      String  @default("CONNECTED") // CONNECTED | ERROR
  lastError   String?
  lastSeenUid Int? // IMAP INBOX incremental cursor

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("email_connections")
}

// ============================================
// Campaigns (bulk outbound to groups of contacts)
// One channel per campaign (EMAIL now; WHATSAPP + others as bots connect).
// Audience = filtered leads/clients + manual include/exclude. Sending runs in
// the API (background loop, per-channel rate limit); a scheduler launches due
// SCHEDULED campaigns. Suppression list enforces opt-out / GDPR.
// ============================================
model Campaign {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  channel Channel @default(EMAIL)
  botId   String? // the connected bot/channel used to send
  bot     Bot?    @relation(fields: [botId], references: [id], onDelete: SetNull)

  subject String? // EMAIL only
  body    String  // template with {nombre} {empresa} {email} placeholders
  agentId String? // optional: agent that handles REPLIES from this campaign's recipients

  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime? // null = send immediately on launch

  // Audience snapshot: { entity, statuses[], sources[], ownerId, includeIds[], excludeIds[] }
  audience Json?

  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  failedCount     Int @default(0)

  createdByUserId String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recipients CampaignRecipient[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  leadId   String?
  clientId String?
  name     String?
  address  String // email or phone (the channel-native destination)

  status    CampaignRecipientStatus @default(PENDING)
  error     String?
  messageId String?
  sentAt    DateTime?
  openedAt  DateTime? // first open (EMAIL tracking pixel)
  openCount Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([campaignId, address])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}

model Suppression {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel  Channel
  address  String // email or phone
  reason   String  @default("UNSUBSCRIBE") // UNSUBSCRIBE | MANUAL | BOUNCE

  createdAt DateTime @default(now())

  @@unique([tenantId, channel, address])
  @@index([tenantId, channel])
  @@map("suppressions")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

# ============================================
# converflow.ai — environment variables
# Copy to .env and fill with real values.
# NEVER commit .env to git.
# ============================================

NODE_ENV=development

# --- Database ---
# Local dev uses docker compose postgres on port 5432
DATABASE_URL=postgresql://converflow:converflow@localhost:5432/converflow?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-32-byte-secret
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# --- API ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# --- Web ---
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Admin (super admin) ---
# Admin uses a different cookie domain & subdomain in prod
ADMIN_PUBLIC_URL=http://localhost:3000/admin
SUPER_ADMIN_BOOTSTRAP_EMAIL=jose@csodigital.tech

# --- LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@converflow.ai

# --- Encryption (Baileys auth state + secrets) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=changeme-generate-64-hex-chars

# --- Storage (object storage for documents, OCR) ---
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=converflow-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=converflow

# --- Bot runner ---
BOT_RUNNER_PORT=4100
BOT_RUNNER_INTERNAL_TOKEN=changeme-shared-token-between-api-and-runner

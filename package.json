{
  "name": "converflow-app",
  "version": "0.0.0",
  "private": true,
  "description": "converflow.ai — multitenant SaaS platform for AI agents that automate commercial processes",
  "packageManager": "pnpm@9.15.0+sha256.09a8fe31a34fda706354680619f4002f4ccef6dadff93240d24ef6c831f0fd28",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "db:generate": "pnpm --filter @converflow/db generate",
    "db:migrate": "pnpm --filter @converflow/db migrate",
    "db:seed": "pnpm --filter @converflow/db seed",
    "db:studio": "pnpm --filter @converflow/db studio",
    "infra:dev": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "infra:dev:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "infra:dev:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1",
      "fastify": "4.28.1",
      "@fastify/helmet": "11.1.1",
      "@fastify/cookie": "9.4.0",
      "@fastify/rate-limit": "9.1.0"
    }
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "AUTH_SECRET",
    "ENCRYPTION_KEY",
    "API_PORT",
    "API_PUBLIC_URL",
    "WEB_PORT",
    "WEB_PUBLIC_URL",
    "ADMIN_PUBLIC_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_SITE_URL",
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_DEFAULT_MODEL",
    "ANTHROPIC_FAST_MODEL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "SUPER_ADMIN_BOOTSTRAP_EMAIL",
    "BOT_RUNNER_PORT",
    "BOT_RUNNER_INTERNAL_TOKEN",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "generate": {
      "cache": false,
      "outputs": ["src/generated/**"]
    }
  }
}
